# AWS AgentCore Configuration
# Copy this file to .env and fill in your values

# Agent ARN (required)
# Get this from your deployed agent or launch_result.pkl
AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:YOUR_ACCOUNT:runtime/YOUR_AGENT_ID

# AWS Region (optional, default: us-east-1)
AWS_REGION=us-east-1

# Server Port (optional, default: 8080)
PORT=8080
