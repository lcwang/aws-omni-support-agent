# AWS Configuration
# Region will be auto-detected from boto3 session if not set
# Priority: AWS_REGION > AWS_DEFAULT_REGION > boto3 session > EC2 metadata > us-east-1
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# SSM Parameter Store Paths
# Override these if your SSM parameters have different names
# SSM_GATEWAY_PARAM=/support/agentgateway/aws_support_gateway
# SSM_KB_PARAM=/support/knowledge_base/kb_id

# Bedrock Model Configuration
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-5-20251101-v1:0
# MODEL_TEMPERATURE=0.3

# Timeout and Retry Configuration (in seconds)
# SSM_TIMEOUT=10
# MCP_TIMEOUT=30
# MAX_RETRIES=3

# Initialization Mode
# - eager: Initialize at module load (DEFAULT for AgentCore Runtime/Lambda)
# - lazy: Initialize on first request (for development/testing)
# INIT_MODE=eager

# Logging Level
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Notes:
# - All values shown are defaults and can be omitted
# - Uncomment and modify only the values you need to change
# - This file should NOT be committed to version control
# - In Lambda/AgentCore Runtime, set these via environment variables in the deployment config
